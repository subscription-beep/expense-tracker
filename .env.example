# Supabase Configuration
# Get these values from your Supabase project dashboard

# Your Supabase project URL
# Found in: Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase publishable/anon key
# Found in: Settings > API > anon public key
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# PostgreSQL Connection String (optional, for backend use)
# Found in: Settings > Database > Connection String > URI
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres
